NODE_ENV=development
PORT=5000

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nat_09

JWT_SECRET=replace_with_a_long_random_string

CLIENT_URL=http://localhost:5173,https://your-frontend.onrender.com

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable key is safe to expose client-side - served to the browser via
# GET /api/payments/config so the client can mount Stripe Elements. Only
# used when PAYMENT_MODE is 'test' or 'live'.
STRIPE_PUBLISHABLE_KEY=

# PAYMENT_MODE controls which payment backend is used:
#   mock - no Stripe account needed; simulates success/failure locally,
#          runs the exact same order-confirmation pipeline (stock, email,
#          PDF receipt) as a real payment. Default for local dev.
#   test - uses STRIPE_SECRET_KEY (a sk_test_... key) against Stripe's
#          test mode. Use this once you have a Stripe account.
#   live - uses STRIPE_SECRET_KEY (a sk_live_... key). Production only.
PAYMENT_MODE=mock

# SMTP for order confirmation emails. Leave blank in local dev - emails are
# logged to the console and the rendered HTML + PDF receipt are saved under
# server/tmp/emails/ instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="NaturallyU <orders@naturallyu.com>"

# Used only by `npm run seed` to create the first admin user
SEED_ADMIN_EMAIL=admin@naturallyu.com
SEED_ADMIN_PASSWORD=change_this_password
